{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quotio",
  "version": "0.5.0",
  "identifier": "dev.quotio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Quotio",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": false
      },
      {
        "label": "menubar",
        "url": "index.html#menubar",
        "title": "Quotio",
        "width": 280,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* http://localhost:* https: ipc: tauri:; img-src 'self' data: blob: asset: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../resources/proxy": "resources/proxy",
      "../../../resources/kiro": "resources/kiro"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4MjYxMkRBNjMyM0MzMDUKUldRRnd5TmoyaElteVB2eUpEaU42VTB0YTVqTEszUjBDcnJjT0lnZWM3SzZFeTdwRlFBQTByQ0sK",
      "endpoints": [
        "https://ghfast.top/https://github.com/xiaocoss/quotio-desktop/releases/latest/download/latest.json",
        "https://gh.ddlc.top/https://github.com/xiaocoss/quotio-desktop/releases/latest/download/latest.json",
        "https://github.com/xiaocoss/quotio-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
