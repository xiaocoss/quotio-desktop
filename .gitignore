xray-client-test.json

# downloaded proxy binaries
resources/proxy/**/*.exe
resources/proxy/**/CLIProxyAPI*
resources/proxy/**/cli-proxy-api*

# kiro-rs sidecar binary (bundled separately, not committed)
resources/kiro/**/*.exe
resources/kiro/**/kiro-rs*

# Tauri generated files
apps/desktop/src-tauri/gen/schemas/

# OS / editor / local assistant config
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/
.claude/
